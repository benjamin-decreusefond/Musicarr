{
  "name": "musicarr",
  "version": "1.0.0",
  "description": "Self-hosted Spotify-like music app: Deezer metadata, Soulseek (slskd) downloads, SQLite storage",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "test": "node --test server/test/*.test.js",
    "coverage": "node --test --experimental-test-coverage --test-coverage-exclude='server/test/**' --test-coverage-exclude='server/index.js' --test-coverage-lines=99 --test-coverage-functions=90 --test-coverage-branches=78 server/test/*.test.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.10.0",
    "express": "^4.21.2",
    "music-metadata": "^11.13.0"
  }
}
